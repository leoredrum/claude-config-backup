# cc-haha 环境变量配置模板
# 复制此文件为 .env 并填入真实的 API 密钥

# LiteLLM 代理地址（指向本地 litellm 服务）
ANTHROPIC_BASE_URL=http://localhost:4000

# Anthropic API 密钥（litellm 代理需要，可以是任意值）
ANTHROPIC_API_KEY=sk-litellm-proxy

# 智谱 AI API 密钥（必需，从 https://open.bigmodel.cn/ 获取）
ZHIPUAI_API_KEY=your-zhipuai-api-key-here

# Ollama 本地服务地址
OLLAMA_HOST=http://localhost:11434

# 可选：设置默认模型
# 主 Agent 使用智谱 GLM-4-Plus
MAIN_AGENT_MODEL=glm-4-plus

# 子 Agent 使用本地 Ollama
SUB_AGENT_MODEL=qwen2.5-coder:32b
